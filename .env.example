# =============================================================================
# mkt-stack — variables de entorno
# Copiar a .env y completar. NUNCA commitear .env (ver .gitignore).
# Generar los secretos con: ./scripts/gen-secrets.sh
# =============================================================================

# --- General ---------------------------------------------------------------
TZ=America/Argentina/Buenos_Aires
# Nombre EXACTO de la red Docker externa a la que ya esta conectado tu NPM.
NPM_NETWORK=npm_network
# Registro desde el que tu servidor hace `docker compose pull`. Lo publica el
# workflow de GitHub Actions (mirror a GHCR). Para pullear imagenes upstream
# directas en vez del mirror, cambialo (no recomendado; rompe el pin propio).
REGISTRY=ghcr.io/pel-matiasvaldivia/mkt-stack

# --- Dominios (los que va a servir NPM por HTTPS) --------------------------
# Un subdominio por servicio, apuntando (registro A) a la IP del VPS.
N8N_HOST=n8n.tudominio.com
TWENTY_SERVER_URL=https://crm.tudominio.com
CALCOM_WEBAPP_URL=https://cal.tudominio.com
PLAUSIBLE_BASE_URL=https://analytics.tudominio.com
# Listmonk y open-wa no exponen dominio publico obligatorio:
# Listmonk se puede publicar en mail.tudominio.com (opcional).
# open-wa queda SOLO en la red interna (lo consume n8n).

# --- SMTP relay (Brevo / Amazon SES). NO se monta MTA propio. --------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=CustOS <hola@tudominio.com>

# --- Postgres compartido (n8n, calcom, listmonk, plausible) ----------------
POSTGRES_USER=mktstack
POSTGRES_PASSWORD=CHANGE_ME_gen-secrets

# --- n8n -------------------------------------------------------------------
N8N_ENCRYPTION_KEY=CHANGE_ME_gen-secrets
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_gen-secrets

# --- Twenty (CRM) ----------------------------------------------------------
TWENTY_PG_PASSWORD=CHANGE_ME_gen-secrets
TWENTY_APP_SECRET=CHANGE_ME_gen-secrets

# --- Cal.com ---------------------------------------------------------------
CALCOM_NEXTAUTH_SECRET=CHANGE_ME_gen-secrets
# CALENDSO_ENCRYPTION_KEY debe ser una clave de 32 caracteres.
CALCOM_ENCRYPTION_KEY=CHANGE_ME_gen-secrets

# --- Listmonk --------------------------------------------------------------
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=CHANGE_ME_gen-secrets

# --- Plausible -------------------------------------------------------------
# SECRET_KEY_BASE debe tener >= 64 caracteres.
PLAUSIBLE_SECRET_KEY_BASE=CHANGE_ME_gen-secrets
PLAUSIBLE_DISABLE_REGISTRATION=invite_only
# Clave del usuario `plausible` de ClickHouse (la usa Plausible para conectarse).
# Alfanumerica (sin caracteres raros): va dentro de una URL http://user:pass@...
CLICKHOUSE_PASSWORD=CHANGE_ME_gen-secrets

# --- open-wa (WhatsApp) ----------------------------------------------------
# Clave de API que usa n8n para llamar a open-wa. Que sea larga y random.
OPENWA_API_KEY=CHANGE_ME_gen-secrets
