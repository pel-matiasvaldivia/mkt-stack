<?xml version="1.0"?>
<!-- Config de USUARIOS (users.d/). SOLO perfiles: ajustes por sesion del perfil
     `default`. Nada de config de servidor aca (eso rompe la carga del usuario
     `default` y provoca AUTHENTICATION_FAILED en ClickHouse). -->
<clickhouse>
    <profiles>
        <default>
            <max_memory_usage>1000000000</max_memory_usage>
            <max_bytes_before_external_group_by>0</max_bytes_before_external_group_by>
            <log_queries>0</log_queries>
            <log_query_threads>0</log_query_threads>
        </default>
    </profiles>
</clickhouse>
