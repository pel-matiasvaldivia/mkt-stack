<?xml version="1.0"?>
<!-- Baja el ruido de logs y desactiva tablas de sistema pesadas que solo
     comen disco en un uso chico como el de Plausible. -->
<clickhouse>
    <profiles>
        <default>
            <log_queries>0</log_queries>
            <log_query_threads>0</log_query_threads>
        </default>
    </profiles>
    <asynchronous_metric_log remove="1"/>
    <metric_log remove="1"/>
    <query_thread_log remove="1"/>
    <query_log remove="1"/>
    <trace_log remove="1"/>
</clickhouse>
